{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CodexReviewResult",
  "type": "object",
  "additionalProperties": false,
  "required": ["summary", "findings", "verdict"],
  "properties": {
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["has_blockers", "has_important", "files_touched", "suggested_next_actions"],
      "properties": {
        "has_blockers": { "type": "boolean" },
        "has_important": { "type": "boolean" },
        "files_touched": {
          "type": "array",
          "items": { "type": "string" }
        },
        "suggested_next_actions": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "title", "explanation", "location", "recommendation"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["BLOCKER", "IMPORTANT", "NIT"]
          },
          "title": { "type": "string" },
          "explanation": { "type": "string" },
          "location": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "line_start", "line_end"],
            "properties": {
              "path": { "type": "string" },
              "line_start": { "type": "integer", "minimum": 1 },
              "line_end": { "type": "integer", "minimum": 1 }
            }
          },
          "recommendation": { "type": "string" }
        }
      }
    },
    "verdict": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "confidence", "rationale"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pass", "fail", "needs_human_review"]
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "rationale": { "type": "string" }
      }
    }
  }
}
