+def append_ledger(
+    project_dir: Path,
+    tool: str,
+    decision: str,
+    reason: str,
+    *,
+    rel_path: str | None = None,
+    command: str | None = None,
+) -> None:
+    """Append a structured audit decision without affecting enforcement."""
+    logger = logging.getLogger(HOOK_NAME)
+    logger.info("entry: append_ledger tool=%s decision=%s reason=%s path=%s", tool, decision, reason, rel_path or "")
+    started = time.perf_counter()
+    try:
+        ledger_path = project_dir / SKIP_LEDGER_REL
+        ledger_path.parent.mkdir(parents=True, exist_ok=True)
+        entry = {
+            "ts": datetime.now(timezone.utc).isoformat(),
+            "tool": tool,
+            "decision": decision,
+            "reason": reason,
+        }
+        if rel_path:
+            entry["path"] = rel_path
+        if command:
+            entry["cmd"] = command[:1000]
+        with ledger_path.open("a", encoding="utf-8") as fh:
+            fh.write(json.dumps(entry, ensure_ascii=False, sort_keys=True) + "\n")
+            fh.flush()
+    except OSError as exc:
+        logger.exception("append_ledger.failed path=%s exc=%s", SKIP_LEDGER_REL, exc)
+    finally:
+        duration_ms = round((time.perf_counter() - started) * 1000, 3)
+        logger.info("exit: append_ledger duration_ms=%s decision=%s reason=%s", duration_ms, decision, reason)
