+def _clean_command_path(raw: str) -> str:
+    """Normalize a shell token that may represent a path."""
+    return raw.strip().strip("'\"").rstrip(",);]").replace("\\", "/")
+
+def _command_has_code_extension(raw: str) -> bool:
+    """True iff a shell token points at a delegated code extension."""
+    return Path(_clean_command_path(raw)).suffix.lower() in CODE_EXTENSIONS
+
+def _is_dual_tool_script(raw: str) -> bool:
+    """True iff raw points at one of the project dual workflow scripts."""
+    normalized = _clean_command_path(raw)
+    while normalized.startswith("./"):
+        normalized = normalized[2:]
+    return normalized in _DUAL_TOOL_SCRIPTS or Path(normalized).name in _DUAL_TOOL_BASENAMES
+
+def _split_shell_tokens(command: str) -> list[str]:
+    """Tokenize a Bash command best-effort with shlex fallback."""
+    logger = logging.getLogger(HOOK_NAME)
+    logger.info("entry: _split_shell_tokens command_len=%d", len(command))
+    started = time.perf_counter()
+    try:
+        tokens = shlex.split(command, posix=True)
+    except ValueError as exc:
+        logger.exception("_split_shell_tokens.shlex_failed exc=%s", exc)
+        tokens = command.replace("\n", " ").split()
+    duration_ms = round((time.perf_counter() - started) * 1000, 3)
+    logger.info("exit: _split_shell_tokens duration_ms=%s token_count=%d", duration_ms, len(tokens))
+    return tokens
+
+def _split_segments(tokens: list[str]) -> list[list[str]]:
+    """Split shell tokens into simple command segments."""
+    logger = logging.getLogger(HOOK_NAME)
+    logger.info("entry: _split_segments token_count=%d", len(tokens))
+    started = time.perf_counter()
+    segments: list[list[str]] = []
+    current: list[str] = []
+    for token in tokens:
+        if token in _SHELL_SEPARATORS:
+            if current:
+                segments.append(current)
+                current = []
+            continue
+        current.append(token)
+    if current:
+        segments.append(current)
+    duration_ms = round((time.perf_counter() - started) * 1000, 3)
+    logger.info("exit: _split_segments duration_ms=%s segment_count=%d", duration_ms, len(segments))
+    return segments
+
+def _script_from_interpreter(tokens: list[str]) -> tuple[str | None, str | None]:
+    """Return (mode, payload) for interpreter commands."""
+    logger = logging.getLogger(HOOK_NAME)
+    logger.info("entry: _script_from_interpreter token_count=%d", len(tokens))
+    started = time.perf_counter()
+    if not tokens:
+        logger.info("exit: _script_from_interpreter duration_ms=0 decision=empty")
+        return None, None
+    exe = Path(tokens[0]).name.lower()
+    result: tuple[str | None, str | None] = (None, None)
+    if exe == "py":
+        index = 1
+        while index < len(tokens) and tokens[index].startswith("-") and tokens[index] != "-c":
+            if re.fullmatch(r"-\d+(?:\.\d+)?", tokens[index]):
+                index += 1
+                continue
+            break
+        if index < len(tokens):
+            if tokens[index] == "-c" and index + 1 < len(tokens):
+                result = ("inline", tokens[index + 1])
+            elif tokens[index] == "-":
+                result = ("opaque", tokens[index])
+            else:
+                result = ("script", tokens[index])
+    elif exe in {"python", "python3"}:
+        index = 1
+        while index < len(tokens) and tokens[index].startswith("-") and tokens[index] not in {"-c", "-"}:
+            index += 1
+        if index < len(tokens):
+            if tokens[index] == "-c" and index + 1 < len(tokens):
+                result = ("inline", tokens[index + 1])
+            elif tokens[index] == "-":
+                result = ("opaque", tokens[index])
+            else:
+                result = ("script", tokens[index])
+    elif exe in {"bash", "sh"}:
+        if len(tokens) > 1:
+            if tokens[1] in {"-s", "-c"}:
+                result = ("opaque", tokens[1])
+            else:
+                result = ("script", tokens[1])
+    elif exe in {"node", "ruby", "perl"}:
+        for token in tokens[1:]:
+            if token.startswith("-"):
+                continue
+            result = ("script", token)
+            break
+    elif exe == "deno":
+        for token in tokens[1:]:
+            if token in {"run", "task"} or token.startswith("-"):
+                continue
+            result = ("script", token)
+            break
+    duration_ms = round((time.perf_counter() - started) * 1000, 3)
+    logger.info("exit: _script_from_interpreter duration_ms=%s decision=%s", duration_ms, result[0] or "none")
+    return result
+
+def _python_inline_targets(code: str) -> list[str]:
+    """Extract paths from simple Python inline file mutation patterns."""
+    logger = logging.getLogger(HOOK_NAME)
+    logger.info("entry: _python_inline_targets code_len=%d", len(code))
+    started = time.perf_counter()
+    targets: list[str] = []
+    for regex in (_PY_OPEN_WRITE_RE, _PY_SHUTIL_COPY_RE, _PY_PATH_WRITE_RE):
+        targets.extend(match.group(1) for match in regex.finditer(code))
+    duration_ms = round((time.perf_counter() - started) * 1000, 3)
+    logger.info("exit: _python_inline_targets duration_ms=%s target_count=%d", duration_ms, len(targets))
+    return targets
+
+def _powershell_targets(script: str) -> list[str]:
+    """Extract target paths from supported PowerShell mutating forms."""
+    logger = logging.getLogger(HOOK_NAME)
+    logger.info("entry: _powershell_targets script_len=%d", len(script))
+    started = time.perf_counter()
+    targets: list[str] = []
+    targets.extend(match.group(1) for match in _PS_FILE_WRITE_RE.finditer(script))
+    tokens = _split_shell_tokens(script)
+    if tokens:
+        lower = [token.lower() for token in tokens]
+        command = lower[0]
+        if command in _POWERSHELL_MUTATORS or command == "new-item":
+            for index, token in enumerate(lower[:-1]):
+                if token in {"-path", "-literalpath", "-filepath"}:
+                    targets.append(tokens[index + 1])
+                if token == "-destination":
+                    targets = [tokens[index + 1]]
+            if not targets and len(tokens) > 1:
+                candidates = [token for token in tokens[1:] if not token.startswith("-")]
+                if candidates:
+                    targets.append(candidates[-1])
+            if command == "new-item" and "file" not in lower:
+                targets = []
+    duration_ms = round((time.perf_counter() - started) * 1000, 3)
+    logger.info("exit: _powershell_targets duration_ms=%s target_count=%d", duration_ms, len(targets))
+    return targets
+
+def _dirty_code_paths(project_dir: Path) -> list[str]:
+    """Return dirty code paths for git reset --hard interception."""
+    logger = logging.getLogger(HOOK_NAME)
+    logger.info("entry: _dirty_code_paths project=%s", project_dir)
+    started = time.perf_counter()
+    try:
+        result = subprocess.run(
+            ["git", "status", "--porcelain"],
+            cwd=project_dir,
+            check=False,
+            capture_output=True,
+            text=True,
+            timeout=5,
+        )
+    except (OSError, subprocess.SubprocessError) as exc:
+        logger.exception("_dirty_code_paths.git_failed exc=%s", exc)
+        logger.info("exit: _dirty_code_paths duration_ms=%s target_count=0", round((time.perf_counter() - started) * 1000, 3))
+        return []
+    paths: list[str] = []
+    if result.returncode == 0:
+        for line in result.stdout.splitlines():
+            raw = line[3:] if len(line) > 3 else ""
+            if " -> " in raw:
+                raw = raw.split(" -> ", 1)[1]
+            rel = _clean_command_path(raw)
+            if is_code_extension(rel):
+                paths.append(rel)
+    duration_ms = round((time.perf_counter() - started) * 1000, 3)
+    logger.info("exit: _dirty_code_paths duration_ms=%s target_count=%d", duration_ms, len(paths))
+    return paths
+
+def _is_whitelisted_segment(tokens: list[str]) -> bool:
+    """True iff a Bash segment is explicitly read-only/project-safe."""
+    logger = logging.getLogger(HOOK_NAME)
+    logger.info("entry: _is_whitelisted_segment token_count=%d", len(tokens))
+    started = time.perf_counter()
+    if not tokens:
+        logger.info("exit: _is_whitelisted_segment duration_ms=0 decision=True")
+        return True
+    exe = Path(tokens[0]).name.lower()
+    lower = [token.lower() for token in tokens]
+    decision = False
+    if exe in _READ_ONLY_VERBS:
+        decision = exe != "find" or ("-delete" not in lower and not ("-exec" in lower and "rm" in lower))
+    elif exe == "git" and len(tokens) > 1:
+        sub = lower[1]
+        decision = (
+            sub in {"status", "log", "diff", "show", "blame", "ls-files", "rev-parse", "remote", "fetch"}
+            or (sub == "branch" and "--show-current" in lower)
+            or (sub == "worktree" and len(tokens) > 2 and lower[2] == "list")
+        )
+    elif exe == "uv" and len(tokens) > 1:
+        decision = lower[1] in {"sync", "lock"} or (len(tokens) > 2 and lower[1] == "run" and lower[2] == "pytest")
+    elif exe in {"pytest", "unittest", "mypy"}:
+        decision = True
+    elif exe == "ruff":
+        decision = len(tokens) > 1 and lower[1] == "check" and "--fix" not in lower
+        decision = decision or (len(tokens) > 2 and lower[1] == "format" and "--check" in lower)
+    elif exe in {"npm", "yarn"}:
+        decision = len(tokens) > 1 and lower[1] in {"test", "install"}
+    elif exe == "pnpm":
+        decision = len(tokens) > 1 and lower[1] == "install"
+    elif exe == "pip":
+        decision = len(tokens) > 1 and lower[1] == "install"
+    elif exe == "cargo":
+        decision = len(tokens) > 1 and lower[1] in {"test", "build"}
+    elif exe == "go":
+        decision = len(tokens) > 1 and lower[1] in {"test", "mod"}
+    elif exe == "tsc":
+        decision = "--noemit" in lower
+    elif exe == "eslint":
+        decision = "--fix" not in lower
+    elif exe == "prettier":
+        decision = "--check" in lower
+    mode, script = _script_from_interpreter(tokens)
+    if mode == "script" and script and _is_dual_tool_script(script):
+        decision = True
+    duration_ms = round((time.perf_counter() - started) * 1000, 3)
+    logger.info("exit: _is_whitelisted_segment duration_ms=%s decision=%s", duration_ms, decision)
+    return decision
+
+def analyze_bash_command(project_dir: Path, command: str) -> tuple[list[str], str]:
+    """Return Bash mutation targets plus allow reason when no cover is needed."""
+    logger = logging.getLogger(HOOK_NAME)
+    logger.info("entry: analyze_bash_command command_len=%d", len(command))
+    started = time.perf_counter()
+    targets: list[str] = []
+    opaque_requires_cover = False
+    for match in _REDIRECT_TARGET_RE.finditer(command):
+        targets.append(match.group(1))
+    tokens = _split_shell_tokens(command)
+    segments = _split_segments(tokens)
+    all_whitelisted = bool(segments)
+    for segment in segments:
+        if not _is_whitelisted_segment(segment):
+            all_whitelisted = False
+        exe = Path(segment[0]).name.lower() if segment else ""
+        lower = [token.lower() for token in segment]
+        if exe in _MUTATING_VERBS:
+            if exe == "rm":
+                targets.extend(token for token in segment[1:] if not token.startswith("-"))
+            else:
+                candidates = [token for token in segment[1:] if not token.startswith("-")]
+                if candidates:
+                    targets.append(candidates[-1])
+        elif exe == "sed" and any(token == "-i" or token.startswith("-i") for token in segment[1:]):
+            targets.extend(token for token in segment[1:] if _command_has_code_extension(token))
+        elif exe == "awk" and "-i" in lower and "inplace" in lower:
+            targets.extend(token for token in segment[1:] if _command_has_code_extension(token))
+        elif exe == "perl" and any(token == "-i" or token.startswith("-i") for token in segment[1:]):
+            targets.extend(token for token in segment[1:] if _command_has_code_extension(token))
+        elif exe == "tee":
+            targets.extend(token for token in segment[1:] if not token.startswith("-"))
+        elif exe == "find" and ("-delete" in lower or ("-exec" in lower and "rm" in lower)):
+            opaque_requires_cover = True
+        elif exe == "git" and len(segment) > 1:
+            sub = lower[1]
+            if sub == "apply":
+                opaque_requires_cover = True
+            elif sub in {"mv", "rm", "restore"}:
+                targets.extend(token for token in segment[2:] if not token.startswith("-"))
+            elif sub == "checkout":
+                targets.extend(token for token in segment[2:] if _command_has_code_extension(token))
+            elif sub == "reset" and "--hard" in lower:
+                targets.extend(_dirty_code_paths(project_dir))
+        elif exe in {"powershell", "pwsh"}:
+            for index, token in enumerate(lower[:-1]):
+                if token in {"-command", "-c"}:
+                    targets.extend(_powershell_targets(segment[index + 1]))
+                    break
+            if exe == "pwsh" and any(token in {"-c", "-command"} for token in lower) and not targets:
+                opaque_requires_cover = True
+        mode, script = _script_from_interpreter(segment)
+        if mode == "opaque":
+            opaque_requires_cover = True
+        elif mode == "inline" and script:
+            targets.extend(_python_inline_targets(script))
+        elif mode == "script" and script and not _is_dual_tool_script(script):
+            if Path(_clean_command_path(script)).suffix.lower() in _SCRIPT_EXTENSIONS:
+                targets.append(script)
+        elif exe not in _INTERPRETERS and _command_has_code_extension(segment[0]):
+            targets.append(segment[0])
+    cleaned: list[str] = []
+    seen: set[str] = set()
+    for target in targets:
+        rel = _clean_command_path(target)
+        if rel and rel not in seen:
+            seen.add(rel)
+            cleaned.append(rel)
+    if opaque_requires_cover and not cleaned:
+        cleaned.append("<opaque-bash-command>")
+    reason = "requires-cover" if cleaned else ("whitelist" if all_whitelisted else "no-code-mutation")
+    duration_ms = round((time.perf_counter() - started) * 1000, 3)
+    logger.info("exit: analyze_bash_command duration_ms=%s target_count=%d decision=%s", duration_ms, len(cleaned), reason)
+    return cleaned, reason
