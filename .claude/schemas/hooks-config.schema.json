{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Claude Code Hooks Configuration",
  "description": "Validates the hooks section of .claude/settings.json",
  "type": "object",
  "properties": {
    "hooks": {
      "type": "object",
      "properties": {
        "SessionStart": { "$ref": "#/$defs/hookEventArray" },
        "PreToolUse": { "$ref": "#/$defs/hookEventArray" },
        "PostToolUse": { "$ref": "#/$defs/hookEventArray" },
        "PostToolUseFailure": { "$ref": "#/$defs/hookEventArray" },
        "PreCompact": { "$ref": "#/$defs/hookEventArray" },
        "TaskCompleted": { "$ref": "#/$defs/hookEventArray" },
        "UserPromptSubmit": { "$ref": "#/$defs/hookEventArray" },
        "Stop": { "$ref": "#/$defs/hookEventArray" },
        "SessionEnd": { "$ref": "#/$defs/hookEventArray" },
        "SubagentStart": { "$ref": "#/$defs/hookEventArray" },
        "SubagentStop": { "$ref": "#/$defs/hookEventArray" },
        "PermissionRequest": { "$ref": "#/$defs/hookEventArray" },
        "WorktreeCreate": { "$ref": "#/$defs/hookEventArray" },
        "WorktreeRemove": { "$ref": "#/$defs/hookEventArray" }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "hookEventArray": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "matcher": { "type": "string" },
          "hooks": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["command"]
                },
                "command": { "type": "string", "minLength": 1 },
                "timeout": { "type": "integer", "minimum": 1, "maximum": 300 }
              },
              "required": ["type", "command"]
            },
            "minItems": 1
          }
        },
        "required": ["hooks"]
      }
    }
  }
}
